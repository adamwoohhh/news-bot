{
  "name": "news-bot",
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "news-bot": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build --compile --outfile dist/news-bot src/index.ts",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile dist/news-bot-darwin-arm64 src/index.ts",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 --outfile dist/news-bot-darwin-x64 src/index.ts",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 --outfile dist/news-bot-linux-arm64 src/index.ts",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 --outfile dist/news-bot-linux-x64 src/index.ts",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 --outfile dist/news-bot-windows-x64.exe src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pinyin-pro": "^3.26.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.6.0"
  }
}
